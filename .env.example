# Database
DATABASE_URL="postgresql://user:password@host:5432/cdr_content_hub?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI (Anthropic Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# Cron Job Security
CRON_SECRET="generate-a-random-secret-min-32-chars"

# Token Encryption (AES-256-GCM) — optional, tokens stored plain text if not set
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Instagram / Meta (Facebook Login for Instagram Business)
META_APP_ID=
META_APP_SECRET=

# TikTok (Login Kit v2)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
